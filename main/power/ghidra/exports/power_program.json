    "opcodes": { "0": "off", "1": "on", "5": "IdentifyCharger", "6": "reset", "8": "shipping", "9": "clear-fault-flags" },
    "reset": "MQTT maintenance/battery/primary/reset -> cmd6 -> 16s -> Standby. Auto fault-recovery in lipo_buck_enable_pgood when monitor+0x121==1 (charger mode 2: 'Battery has generic fault bit set, need to reset battery'): clear-flags(9) -> on(1) -> reset(6) -> on(1).",
    "insertion": "CAN status bits (not GPIO): IsPrimaryInserted=power_control_frame[2]&1; BatteryINS-DET=battery_frame[6]>>5&1; FAIL=battery_frame[6]>>4&1."
  },
